// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique @db.VarChar(255)
  fullName  String   @map("full_name") @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  country   String   @db.VarChar(2)
  kycStatus String   @default("PENDING") @map("kyc_status") @db.VarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts UserAccount[] 

  sentTransfers Transfer[] @relation("SentTransfers")
  receivedTransfers Transfer[] @relation("ReceivedTransfers")

  @@map("users")
}

model UserAccount {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  tigerBeetleAccountId Decimal @map("tigerbeetle_account_id") @db.Decimal(39, 0)
  currency            String   @db.VarChar(4)
  accountType         String   @map("account_type") @db.VarChar(20)
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_accounts")
}


model SystemAccount {
  id                   String   @id @default(uuid()) @db.Uuid
  tigerBeetleAccountId Decimal  @map("tigerbeetle_account_id") @db.Decimal(39, 0)
  currency             String   @db.VarChar(4)
  accountType          String   @map("account_type") @db.VarChar(20)
  createdAt            DateTime @default(now()) @map("created_at")

  @@unique([currency, accountType])
  @@map("system_accounts")
}

model Transfer {
  id                String   @id @default(uuid()) @db.Uuid
  idempotencyKey    String   @unique @map("idempotency_key") @db.VarChar(255)
  type              String   @default("SAME_CURRENCY") @db.VarChar(20)
  senderId          String   @map("sender_id") @db.Uuid
  recipientId       String?  @map("recipient_id") @db.Uuid
  recipientDetails  Json?    @map("recipient_details")
  senderCurrency    String   @map("sender_currency") @db.VarChar(4)
  recipientCurrency String   @map("recipient_currency") @db.VarChar(4)
  amount            Decimal  @db.Decimal(20, 8)
  exchangeRate      Decimal? @map("exchange_rate") @db.Decimal(20, 8)
  convertedAmount   Decimal? @map("converted_amount") @db.Decimal(20, 8)
  providerRef       String?  @map("provider_ref") @db.VarChar(255)
  status            String   @default("INITIATED") @db.VarChar(30)
  failureReason     String?  @map("failure_reason")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sender    User @relation("SentTransfers", fields: [senderId], references: [id])
  recipient User? @relation("ReceivedTransfers", fields: [recipientId], references: [id])
  statusHistory TransferStatusHistory[]
  providerEvents ProviderEvent[]

  @@map("transfers")
}

model TransferStatusHistory {
  id         String   @id @default(uuid()) @db.Uuid
  transferId String   @map("transfer_id") @db.Uuid
  fromStatus String?  @map("from_status") @db.VarChar(30)
  toStatus   String   @map("to_status") @db.VarChar(30)
  changedBy  String   @map("changed_by") @db.VarChar(50)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  transfer Transfer @relation(fields: [transferId], references: [id])

  @@map("transfer_status_history")
}

model ProviderEvent {
  id            String   @id @default(uuid()) @db.Uuid
  transferId    String   @map("transfer_id") @db.Uuid
  provider      String   @db.VarChar(50)    // "on_ramp", "off_ramp", etc.
  eventType     String   @map("event_type") @db.VarChar(50)
  rawStatus     String   @map("raw_status") @db.VarChar(100)
  mappedStatus  String   @map("mapped_status") @db.VarChar(30)
  rawPayload    Json     @map("raw_payload")
  receivedAt    DateTime @default(now()) @map("received_at")

  transfer Transfer @relation(fields: [transferId], references: [id])

  @@map("provider_events")
}